# ── Python backend (Aureonics-OS kernel on Render) ────────────────
# Server-side only — never exposed to the browser.
# Next.js API routes proxy to this URL; if unset, inline fallback runs.
LEX_API_BASE_URL=https://api.lexaureon.com

# ── LLM keys (inline fallback when backend is unavailable) ────────
GROQ_API_KEY=
CLAUDE_API_KEY=

# ── Auth ──────────────────────────────────────────────────────────
# Must match LEX_AUTH_SECRET on the Python backend
LEX_AUTH_SECRET=

# ── Billing ───────────────────────────────────────────────────────
# Set to a Stripe Payment Link URL to enable one-click Pro upgrades.
# If unset, the /api/billing/checkout route proxies to the backend.
# NEXT_PUBLIC_PRO_CHECKOUT_URL=https://buy.stripe.com/xxxxx

# ── Frontend public vars ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://www.lexaureon.com
